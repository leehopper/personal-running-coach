{
  "env": {
    "EVAL_CACHE_MODE": "Replay",
    "CLAUDE_CODE_TASK_LIST_ID": "runcoach"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "[ -n \"$TMPDIR\" ] && mkdir -p \"$TMPDIR\" 2>/dev/null; exit 0"
          }
        ]
      }
    ]
  }
}
