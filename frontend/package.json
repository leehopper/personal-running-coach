{
  "name": "runcoach-frontend",
  "private": true,
  "version": "0.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run codegen",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:codegen-drift": "bash scripts/test-codegen-drift.sh",
    "check-contrast": "tsx scripts/check-contrast.ts",
    "e2e": "playwright test",
    "e2e:clean": "bash scripts/e2e-clean.sh",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "codegen:rtk": "mkdir -p src/app/api/generated/rtk && rtk-query-codegen-openapi ./openapi-config.ts && node scripts/codegen-prepend-header.mjs",
    "codegen:zod": "orval --config ./orval.config.ts",
    "codegen": "npm run codegen:rtk && npm run codegen:zod && prettier --write \"src/app/api/generated/**/*.ts\"",
    "codegen:check": "npm run codegen && git diff --exit-code -- src/app/api/generated ../backend/openapi/swagger.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.8.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/instrumentation": "^0.219.0",
    "@opentelemetry/instrumentation-fetch": "^0.219.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@reduxjs/toolkit": "^2.12.0",
    "@tailwindcss/vite": "^4.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.21.0",
    "radix-ui": "^1.6.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-error-boundary": "^6.1.2",
    "react-hook-form": "^7.80.0",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.18.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@orval/zod": "^8.19.0",
    "@playwright/test": "^1.61.1",
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.9.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "esbuild-runner": "^2.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "eslint-plugin-sonarjs": "^4.1.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "orval": "^8.19.0",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vitest": "^4.1.0"
  }
}
