{
  "name": "runcoach-frontend",
  "private": true,
  "version": "0.0.0",
  "license": "UNLICENSED",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run codegen",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:codegen-drift": "bash scripts/test-codegen-drift.sh",
    "e2e": "playwright test",
    "e2e:clean": "bash scripts/e2e-clean.sh",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "codegen:rtk": "mkdir -p src/app/api/generated/rtk && rtk-query-codegen-openapi ./openapi-config.ts && node scripts/codegen-prepend-header.mjs",
    "codegen:zod": "orval --config ./orval.config.ts",
    "codegen": "npm run codegen:rtk && npm run codegen:zod && prettier --write \"src/app/api/generated/**/*.ts\"",
    "codegen:check": "npm run codegen && git diff --exit-code -- src/app/api/generated ../backend/openapi/swagger.json"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.2.2",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/core": "^2.7.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.218.0",
    "@opentelemetry/instrumentation": "^0.218.0",
    "@opentelemetry/instrumentation-fetch": "^0.218.0",
    "@opentelemetry/resources": "^2.7.1",
    "@opentelemetry/sdk-trace-base": "^2.7.1",
    "@opentelemetry/sdk-trace-web": "^2.7.1",
    "@opentelemetry/semantic-conventions": "^1.37.0",
    "@reduxjs/toolkit": "^2.11.2",
    "@tailwindcss/vite": "^4.2.4",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-error-boundary": "^6.1.1",
    "react-hook-form": "^7.75.0",
    "react-redux": "^9.2.0",
    "react-router-dom": "^7.15.0",
    "tailwindcss": "^4.2.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@orval/zod": "^8.9.1",
    "@playwright/test": "^1.59.1",
    "@rtk-query/codegen-openapi": "^2.2.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.5",
    "esbuild-runner": "^2.2.2",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "eslint-plugin-sonarjs": "^4.0.3",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "orval": "^8.9.1",
    "prettier": "^3.8.3",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.11",
    "vitest": "^4.1.0"
  }
}
