      "contents": [
        {
          "$type": "text",
          "text": "{\"week_number\":1,\"phase_type\":\"Base\",\"weekly_target_km\":15,\"is_deload_week\":false,\"days\":[{\"day_of_week\":0,\"slot_type\":\"Rest\",\"workout_type\":null,\"notes\":\"Full rest day. Use this time to prepare your gear and mentally settle into your new training routine.\"},{\"day_of_week\":1,\"slot_type\":\"Run\",\"workout_type\":\"Easy\",\"notes\":\"Easy 5 km run at a comfortable, conversational pace (7:00–8:00 /km). Focus on breathing steadily and keeping effort low. Walk breaks are perfectly fine.\"},{\"day_of_week\":2,\"slot_type\":\"Rest\",\"workout_type\":null,\"notes\":\"Rest or light walking. Let your legs recover from Monday's run.\"},{\"day_of_week\":3,\"slot_type\":\"Run\",\"workout_type\":\"Easy\",\"notes\":\"Easy 4 km run at 7:00–8:00 /km. Midweek run to build consistency. Keep it relaxed — you should be able to hold a conversation throughout.\"},{\"day_of_week\":4,\"slot_type\":\"Rest\",\"workout_type\":null,\"notes\":\"Rest day. Hydrate well and get good sleep ahead of your long run on Saturday.\"},{\"day_of_week\":5,\"slot_type\":\"Rest\",\"workout_type\":null,\"notes\":\"Rest day. Light stretching or a short walk is fine if you feel like moving.\"},{\"day_of_week\":6,\"slot_type\":\"Run\",\"workout_type\":\"LongRun\",\"notes\":\"Long run of 6 km at an easy, relaxed pace (7:30–8:00 /km). This is your longest effort of the week — go slow, enjoy it, and walk if needed. No time pressure.\"}],\"week_summary\":\"Welcome to Week 1, Sarah! This is your foundation week. The goal is simply to establish the habit of running three times per week at an easy, comfortable effort. All runs should feel manageable — if you can't hold a conversation, slow down. Total volume matches your current weekly distance of 15 km so there's no shock to your system. Consistency is everything right now.\"}"
        }
      ]
